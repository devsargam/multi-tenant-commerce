{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "PORT",
    "DATABASE_URL",
    "NODE_ENV",
    "AUTO_MIGRATE",
    "DRIZZLE_MIGRATIONS_FOLDER",
    "SEED_DEMO_DATA",
    "K8S_APPLY_MODE",
    "KUBECONFIG",
    "NAMESPACE_PREFIX",
    "DEFAULT_IMAGE_REGISTRY",
    "DEFAULT_API_IMAGE",
    "DEFAULT_WEB_IMAGE",
    "DEFAULT_ADMIN_WEB_IMAGE",
    "LOCAL_ACCESS_PORT_BASE",
    "LOCAL_ACCESS_BIND_ADDRESS",
    "KUBECTL_BINARY",
    "VITE_ORCHESTRATOR_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
